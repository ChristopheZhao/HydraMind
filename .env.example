# HydraMind local provider configuration.
#
# Copy this file to `.env` and fill in keys locally. `.env` is ignored by git.
# Model IDs must match what your provider account exposes.

HYDRAMIND_BACKEND=openai_compatible
HYDRAMIND_DEFAULT_PROVIDER=deepseek
HYDRAMIND_DEFAULT_MODEL=deepseek-v4-pro

# DeepSeek V4 Pro: OpenAI-compatible Chat Completions.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=120

# Kimi K2.6. Domestic accounts commonly use moonshot.cn; global accounts may
# use https://api.moonshot.ai/v1 instead.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6
KIMI_TIMEOUT_SECONDS=120

# GLM 5.1. If your key is issued by BigModel instead of Z.AI, set:
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.1
GLM_TIMEOUT_SECONDS=120

# Role routing. These route logical HydraMind roles to providers/models.
# Orchestrator: high-level runtime decision and gate-aware coordination.
HYDRAMIND_ORCHESTRATOR_PROVIDER=deepseek
HYDRAMIND_ORCHESTRATOR_MODEL=deepseek-v4-pro
HYDRAMIND_ORCHESTRATOR_THINKING=false
HYDRAMIND_ORCHESTRATOR_REASONING_EFFORT=
HYDRAMIND_ORCHESTRATOR_TEMPERATURE=0.2

# Planner: long-context task decomposition and prompt/workflow planning.
HYDRAMIND_PLANNER_PROVIDER=kimi
HYDRAMIND_PLANNER_MODEL=kimi-k2.6
HYDRAMIND_PLANNER_THINKING=false
# Kimi K2.x currently accepts temperature=1 only on Moonshot's endpoint.
HYDRAMIND_PLANNER_TEMPERATURE=1

# Executor: implementation/execution-heavy worker turns.
HYDRAMIND_EXECUTOR_PROVIDER=glm
HYDRAMIND_EXECUTOR_MODEL=glm-5.1
HYDRAMIND_EXECUTOR_THINKING=false
HYDRAMIND_EXECUTOR_TEMPERATURE=0.2

# Reviewer: independent review, checkpoint, and gate verdict turns.
HYDRAMIND_REVIEWER_PROVIDER=deepseek
HYDRAMIND_REVIEWER_MODEL=deepseek-v4-pro
HYDRAMIND_REVIEWER_THINKING=false
HYDRAMIND_REVIEWER_REASONING_EFFORT=
HYDRAMIND_REVIEWER_TEMPERATURE=0.1

# Non-standard reasoning fields are opt-in because each provider differs.
# Set *_THINKING=true or *_REASONING_EFFORT=high only when your endpoint
# accepts those OpenAI-compatible extensions.

# Compactor: summarization / memory compression when P1 explicit compaction lands.
HYDRAMIND_COMPACTOR_PROVIDER=kimi
HYDRAMIND_COMPACTOR_MODEL=kimi-k2.6
HYDRAMIND_COMPACTOR_TEMPERATURE=1

# Built-in tools. These are only used when `--live-tools` is set.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_TIMEOUT_SECONDS=30
DOUBAO_API_KEY=
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_IMAGE_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
DOUBAO_IMAGE_TIMEOUT_SECONDS=120
